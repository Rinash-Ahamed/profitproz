# Copy this file to .env.local for development and keep all real values out of source control.
AUTH_SECRET=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Development fallback only. Production accounts belong in Firestore.
ADMIN_EMAIL=
ADMIN_PASSWORD=
STAFF_LOGIN_EMAIL=
STAFF_LOGIN_PASSWORD=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_NOTIFICATION_EMAIL=

# Keep false/unset in production unless audit-log deletion is explicitly approved.
ALLOW_AUDIT_LOG_CLEAR=false

# Payment and company details printed on generated OTA and revenue invoices.
INVOICE_ACCOUNT_NAME=
INVOICE_BANK_NAME=
INVOICE_ACCOUNT_NUMBER=
INVOICE_IFSC_CODE=
INVOICE_UPI_VPA=
INVOICE_UPI_NUMBER=
INVOICE_COMPANY_ADDRESS=
